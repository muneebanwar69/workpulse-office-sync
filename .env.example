# Copy this file to `.env` next to sync.py and fill in the real values.
# `.env` is in .gitignore so your credentials never get committed.

# WorkPulse production backend -- leave default unless you're on a staging URL
WORKPULSE_API=https://hcm-api.owesome.work

# A user in the WorkPulse app that has `devices:manage` + `attendance:create`
# permissions. Strongly recommended: create a dedicated service account
# (e.g. sync-bot@ikonicsolution.com) instead of using your personal CEO login.
WORKPULSE_EMAIL=sync-bot@ikonicsolution.com
WORKPULSE_PASSWORD=change_me

# Company ID in WorkPulse (1 is the default for single-tenant installs)
WORKPULSE_COMPANY_ID=1

# ZKTeco K60 on the LAN
DEVICE_IP=192.168.101.247
DEVICE_PORT=4370

# How many days back to sync on each run.
#   0 = today only
#   1 = yesterday + today (recommended -- catches overnight 4PM-1AM shifts)
#   7 = week-long window (catch-up after downtime)
SYNC_WINDOW_DAYS=1
